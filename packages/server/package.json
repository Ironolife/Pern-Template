{
  "name": "@pern-template/server",
  "version": "0.0.4",
  "main": "dist/index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "watch": "tsc -w",
    "dev": "nodemon dist/index.js",
    "build": "tsc",
    "genenv": "gen-env-types .env -o src/@types/env.d.ts -e .",
    "mig-g": "typeorm migration:generate -n UpdateTables --pretty",
    "mig-c": "typeorm migration:create -n Migration"
  },
  "dependencies": {
    "@pern-template/constants": "*",
    "@pern-template/utils": "*",
    "apollo-server-express": "^2.21.1",
    "class-validator": "^0.13.1",
    "cors": "^2.8.5",
    "dataloader": "^2.0.0",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "graphql": "^15.5.0",
    "jsonwebtoken": "^8.5.1",
    "jwks-rsa": "^2.0.1",
    "pg": "^8.5.1",
    "reflect-metadata": "^0.1.13",
    "type-graphql": "^1.1.1",
    "typeorm": "^0.2.31"
  },
  "devDependencies": {
    "@types/cors": "^2.8.10",
    "@types/express": "^4.17.11",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/pg": "^7.14.11"
  }
}
